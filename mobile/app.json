{
  "expo": {
    "name": "Trove",
    "slug": "trove",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "trove",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trove.app"
    },
    "android": {
      "package": "com.trove.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFF8F0"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/"
    }
  }
}

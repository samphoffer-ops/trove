{
  "expo": {
    "name": "Trove",
    "slug": "trove",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "trove",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1035"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.shoptrove",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Trove uses your photo library to let you set a profile photo.",
        "NSCameraUsageDescription": "Trove uses your camera to let you set a profile photo."
      }
    },
    "android": {
      "package": "app.shoptrove",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#0D1035"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D1035",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/"
    }
  }
}
